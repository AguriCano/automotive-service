### LOCALHOST

### Get all clients
GET http://localhost:3000/clients

### Get single client by ID (replace with a real ID from your database)
GET http://localhost:3000/clients/65f5a1b2c3d4e5f6a7b8c9d0

### Create a new client
POST http://localhost:3000/clients
Content-Type: application/json

{
  "name": "Aguri",
  "last_name": "Cano",
  "phone": "987654321",
  "email": "aguri@email.com",
  "address": "Lima",
  "dni": "71234567",
  "registration_date": "2024-01-10",
  "customer_status": "active"
}

### Update a client (replace with a real ID)
PUT http://localhost:3000/clients/65f5a1b2c3d4e5f6a7b8c9d0
Content-Type: application/json

{
  "name": "Aguri Updated",
  "last_name": "Cano",
  "phone": "987654321",
  "email": "aguri.updated@email.com",
  "address": "Lima",
  "dni": "71234567",
  "registration_date": "2024-01-10",
  "customer_status": "active"
}

### Delete a client (replace with a real ID)
DELETE http://localhost:3000/clients/65f5a1b2c3d4e5f6a7b8c9d0

